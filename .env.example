APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC
ASC_PRIVATE_KEY_DIR=AuthKey
ASC_TOKEN_TTL_SECONDS=1200
ASC_HTTP_TIMEOUT=30
ASC_HTTP_CONNECT_TIMEOUT=10
ASC_HTTP_READ_TIMEOUT=30
ASC_HTTP_MAX_RETRIES=2
ASC_HTTP_RETRY_DELAY_MS=200
ASC_HTTP_RETRYABLE_CODES=408,429,500,502,503,504
ASC_BASE_URL=https://api.appstoreconnect.apple.com
LOG_ENABLED=true
LOG_LEVEL=debug
LOG_HTTP_ENABLED=true
LOG_STDERR_ENABLED=true
LOG_FILEPATH=logs/requests.log
